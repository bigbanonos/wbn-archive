<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CPBL — Chinese Professional Baseball League | Baseball Without Borders</title>
  <meta name="description" content="Chinese Professional Baseball League — Taiwan's top flight. HamiVideo streaming, Wei Chuan Dragons free on YouTube. Premier12 2024 champions.">
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,400;0,700;0,900;1,700;1,900&family=IBM+Plex+Mono:wght@400;500;700&family=Lora:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
  <style>
    :root{--bg:#0a0f1e;--bg2:#0f172a;--card:#111827;--card2:#0d1424;--text:#f0f4ff;--muted:#8899bb;--dim:#4a5a7a;--accent:#D50032;--neon:#00ff9d;--gold:#f5c842;--rule:#1e2d4a;--rule2:#263354;--blue:#38bdf8;--teal:#2dd4bf;--purple:#a78bfa;--lg:#00843d;--mono:'IBM Plex Mono',monospace;--display:'Barlow Condensed',sans-serif;--serif:'Lora',serif;}
    *{box-sizing:border-box;margin:0;padding:0;}
    html{scroll-behavior:smooth;}
    body{background:var(--bg);color:var(--text);font-family:var(--serif);font-size:15px;line-height:1.65;}
    a{text-decoration:none;color:inherit;}
    .site-nav{background:var(--bg2);border-bottom:1px solid var(--rule);padding:12px 24px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;}
    .site-nav .logo{font-family:var(--display);font-weight:900;font-size:.9rem;letter-spacing:1px;}
    .site-nav .navlinks{display:flex;gap:6px;flex-wrap:wrap;}
    .nav-pill{font-family:var(--display);font-size:.7rem;font-weight:700;letter-spacing:1px;padding:4px 12px;border-radius:20px;border:1px solid var(--rule2);color:var(--muted);transition:.2s;}
    .nav-pill:hover{color:var(--text);border-color:var(--text);}
    .nav-pill.active{color:var(--gold);border-color:var(--gold);}
    .hq-link{font-family:var(--display);font-size:.7rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--neon);border:1px solid var(--neon);padding:6px 14px;border-radius:4px;display:flex;align-items:center;gap:8px;}
    .live-dot{width:7px;height:7px;background:var(--neon);border-radius:50%;box-shadow:0 0 5px var(--neon);animation:blink 1.8s infinite;}
    @keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
    .crumbs{padding:14px 24px;background:var(--bg2);border-bottom:1px solid var(--rule);font-family:var(--mono);font-size:.72rem;color:var(--muted);}
    .crumbs a{color:var(--muted);}
    .crumbs a:hover{color:var(--neon);}
    .crumbs span{color:var(--gold);}
    .hero{padding:56px 24px 40px;border-bottom:3px solid var(--lg);position:relative;overflow:hidden;background:linear-gradient(180deg,#020e07 0%,#0a0f1e 100%);}
    .hero::before{content:'';position:absolute;inset:0;background:repeating-linear-gradient(90deg,rgba(0,132,61,.03) 0 1px,transparent 1px 60px),repeating-linear-gradient(0deg,rgba(0,132,61,.03) 0 1px,transparent 1px 60px);pointer-events:none;}
    .hero-inner{max-width:1200px;margin:0 auto;position:relative;}
    .hero-flag{font-family:var(--display);font-size:.68rem;font-weight:700;letter-spacing:5px;text-transform:uppercase;color:var(--lg);margin-bottom:12px;}
    .hero-country{display:flex;align-items:center;gap:18px;margin-bottom:18px;flex-wrap:wrap;}
    .hero-flag-emoji{font-size:3.2rem;line-height:1;}
    .hero-title{font-family:var(--display);font-size:clamp(3.4rem,10vw,8rem);font-weight:900;font-style:italic;line-height:.88;letter-spacing:-2.5px;text-transform:uppercase;}
    .hero-full{font-family:var(--display);font-size:clamp(1rem,2vw,1.4rem);font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--muted);margin-top:8px;margin-bottom:24px;}
    .hero-lede{font-family:var(--serif);font-size:1.1rem;font-style:italic;color:var(--muted);max-width:720px;line-height:1.75;}
    .hero-lede strong{color:var(--text);font-style:normal;}
    .hero-stats{display:flex;gap:32px;flex-wrap:wrap;padding-top:24px;margin-top:24px;border-top:1px solid var(--rule2);}
    .hs-num{font-family:var(--display);font-size:2rem;font-weight:900;line-height:1;color:var(--lg);}
    .hs-num.gold-hs{color:var(--gold);}
    .hs-lbl{font-family:var(--mono);font-size:.6rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-top:4px;}
    .page{max-width:1200px;margin:0 auto;padding:40px 24px 64px;}
    .section{margin-bottom:56px;}
    .section-head{display:flex;align-items:baseline;gap:16px;padding-bottom:14px;margin-bottom:24px;border-bottom:2px solid var(--rule2);}
    .section-num{font-family:var(--mono);font-size:.75rem;color:var(--lg);font-weight:700;letter-spacing:2px;}
    .section-title{font-family:var(--display);font-size:1.6rem;font-weight:900;letter-spacing:-.5px;text-transform:uppercase;}
    .section-sub{font-family:var(--mono);font-size:.7rem;color:var(--muted);margin-left:auto;}
    .platforms{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:14px;}
    .platform-card{background:var(--card);border:1px solid var(--rule);border-radius:8px;padding:18px 20px;transition:.15s;border-left:4px solid var(--rule2);}
    .platform-card:hover{border-color:var(--rule2);transform:translateY(-2px);}
    .platform-card.premium{border-left-color:var(--lg);}
    .platform-card.free{border-left-color:var(--neon);}
    .platform-card.exclusive{border-left-color:var(--gold);}
    .platform-name{font-family:var(--display);font-size:1.1rem;font-weight:900;letter-spacing:-.3px;margin-bottom:4px;}
    .platform-tag{font-family:var(--mono);font-size:.58rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;padding:2px 7px;border-radius:3px;display:inline-block;margin-bottom:10px;background:rgba(255,255,255,.05);color:var(--lg);}
    .tag-free{background:rgba(0,255,157,.1);color:var(--neon);}
    .tag-exclusive{background:rgba(245,200,66,.12);color:var(--gold);}
    .platform-cost{font-family:var(--mono);font-size:.85rem;color:var(--text);font-weight:700;margin-bottom:6px;}
    .platform-cost.free{color:var(--neon);}
    .platform-desc{font-family:var(--serif);font-size:.85rem;color:var(--muted);line-height:1.6;}
    .platform-desc strong{color:var(--text);}
    .platform-link{display:inline-block;margin-top:10px;font-family:var(--mono);font-size:.7rem;color:var(--lg);font-weight:700;}
    .platform-link:hover{color:var(--neon);}
    .watch-window{background:rgba(245,200,66,.06);border:1px solid rgba(245,200,66,.2);border-left:4px solid var(--gold);border-radius:6px;padding:20px 24px;margin-bottom:32px;}
    .watch-window.neon{background:rgba(0,255,157,.04);border-color:rgba(0,255,157,.2);border-left-color:var(--neon);}
    .ww-title{font-family:var(--display);font-size:1.1rem;font-weight:900;color:var(--gold);letter-spacing:1px;text-transform:uppercase;margin-bottom:8px;}
    .watch-window.neon .ww-title{color:var(--neon);}
    .ww-lede{font-family:var(--serif);font-size:.92rem;color:var(--muted);line-height:1.7;margin-bottom:12px;}
    .ww-lede strong{color:var(--text);}
    .ww-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:10px;margin-top:14px;}
    .ww-item{background:rgba(0,0,0,.25);border:1px solid var(--rule);border-radius:4px;padding:10px 12px;}
    .ww-val{font-family:var(--mono);font-size:.9rem;font-weight:700;color:var(--gold);}
    .ww-val.neon-val{color:var(--neon);}
    .ww-lbl{font-family:var(--mono);font-size:.6rem;color:var(--muted);margin-top:2px;text-transform:uppercase;letter-spacing:1px;}
    .timeline{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:12px;}
    .tl-item{background:var(--card);border:1px solid var(--rule);border-radius:6px;padding:14px 16px;}
    .tl-date{font-family:var(--mono);font-size:.65rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--lg);margin-bottom:6px;}
    .tl-title{font-family:var(--display);font-size:1rem;font-weight:900;letter-spacing:-.3px;margin-bottom:4px;}
    .tl-desc{font-family:var(--serif);font-size:.82rem;color:var(--muted);line-height:1.55;}
    .divisions-wrap{background:var(--card);border:1px solid var(--rule);border-radius:10px;overflow:hidden;}
    .div-block{padding:20px 24px;border-bottom:1px solid var(--rule);}
    .div-block:last-child{border-bottom:none;}
    .div-title{font-family:var(--display);font-size:.95rem;font-weight:900;letter-spacing:2px;text-transform:uppercase;margin-bottom:12px;color:var(--lg);}
    .div-teams{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:8px;}
    .team-row{font-family:var(--serif);font-size:.88rem;color:var(--muted);padding:4px 0;}
    .team-row strong{color:var(--text);font-family:var(--display);font-weight:700;letter-spacing:.2px;}
    .did-you-know{background:linear-gradient(135deg,rgba(245,200,66,.06) 0%,rgba(245,200,66,.02) 100%);border:1px solid rgba(245,200,66,.2);border-left:5px solid var(--gold);border-radius:0 8px 8px 0;padding:20px 28px;margin-bottom:32px;}
    .dyk-badge{font-family:var(--display);font-size:.62rem;font-weight:900;letter-spacing:3px;text-transform:uppercase;color:#000;background:var(--gold);padding:4px 10px;border-radius:3px;display:inline-block;margin-bottom:14px;}
    .dyk-title{font-family:var(--display);font-size:1.3rem;font-weight:900;letter-spacing:-.3px;margin-bottom:10px;}
    .dyk-body{font-family:var(--serif);font-size:.95rem;color:var(--muted);line-height:1.75;font-style:italic;}
    .dyk-body strong{color:var(--text);font-style:normal;}
    .footer{border-top:2px solid var(--lg);padding:32px 24px;margin-top:40px;background:var(--bg2);}
    .footer-inner{max-width:1200px;margin:0 auto;display:flex;justify-content:space-between;flex-wrap:wrap;gap:20px;}
    .gf-brand{font-family:var(--display);font-size:1.3rem;font-weight:900;letter-spacing:1px;}
    .gf-pub{font-family:var(--mono);font-size:.7rem;color:var(--muted);margin-top:6px;}
    .gf-pub a{color:var(--muted);}
    .gf-pub a:hover{color:var(--neon);}
    .gf-links{display:flex;gap:12px;flex-wrap:wrap;justify-content:flex-end;}
    .gf-link{font-family:var(--mono);font-size:.72rem;color:var(--muted);}
    .gf-link:hover{color:var(--neon);}
  </style>
</head>
